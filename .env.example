# ─── Groq (Free LLM) ──────────────────────────────────────────────────────
# Sign up FREE at https://console.groq.com
# Free tier: 14,400 requests/day, 30 req/min, no credit card needed
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CORS (optional but recommended) ────────────────────────────────────
# Comma-separated list of allowed origins.
# If empty, all origins are allowed (fine for Vercel where URL is known).
# Example: https://your-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=https://your-app.vercel.app

# ─── Node environment ────────────────────────────────────────────────────
NODE_ENV=production
# ─── OpenRouter (Fallback 1) ─────────────────────────────────────────────
# Set to an OpenRouter API key. Free tier covers llama-3-70b/8b, etc.
OPENROUTER_API_KEY=sk-or-v1-0xxxxxxxxxx

# ─── Nebius (Fallback 2) ─────────────────────────────────────────────────
# Set to a Nebius AI Studio API key.
NEBIUS_API_KEY=v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
